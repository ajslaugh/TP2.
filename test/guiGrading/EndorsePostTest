package guiGrading;

import static org.junit.jupiter.api.Assertions.*;

import java.sql.SQLException;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;

import database.Database;
import entityClasses.Post;

/**
 * <p>Title: EndorsePostTest</p>
 *
 * <p>Description: JUnit 5 test class for the endorsePost method in the Database class.
 * Tests valid and invalid post ID cases.</p>
 *
 * <p>This test verifies that a valid post ID returns true, and invalid or zero post IDs return false.</p>
 *
 * @author Jerry
 * @version 1.0
 */
public class EndorsePostTest {

    /** <p>Database instance used for testing</p> */
    private Database db;

    /** <p>Stores the ID of the test post created in setup</p> */
    private int testPostId;

    /**
     * <p>Method: setUp()</p>
     *
     * <p>Description: Runs before each test. Creates a database connection,
     * inserts a test post, and retrieves a valid post ID.</p>
     *
     * @throws SQLException if a database error occurs
     */
    @BeforeEach
    public void setUp() throws SQLException {
        db = new Database();
        db.connectToDatabase();

        Post post = new Post("testStudent", "STUDENT", "This is a test post", "General");
        db.addPost(post);

        testPostId = db.getNumberOfPosts();
        assertTrue(testPostId > 0, "Test post should be inserted successfully");
    }

    /**
     * <p>Method: testEndorsePost_Valid()</p>
     *
     * <p>Description: Verifies that endorsePost returns true for a valid post ID.</p>
     */
    @Test
    public void testEndorsePost_Valid() {
        boolean result = db.endorsePost(testPostId);
        assertTrue(result, "endorsePost should return true for a valid post ID");
    }

    /**
     * <p>Method: testEndorsePost_InvalidPostID()</p>
     *
     * <p>Description: Verifies that endorsePost returns false for an invalid post ID.</p>
     */
    @Test
    public void testEndorsePost_InvalidPostID() {
        boolean result = db.endorsePost(-1);
        assertFalse(result, "endorsePost should return false for an invalid post ID");
    }

    /**
     * <p>Method: testEndorsePost_ZeroPostID()</p>
     *
     * <p>Description: Verifies that endorsePost returns false for post ID 0.</p>
     */
    @Test
    public void testEndorsePost_ZeroPostID() {
        boolean result = db.endorsePost(0);
        assertFalse(result, "endorsePost should return false for post ID 0");
    }
